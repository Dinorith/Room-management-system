################################################################################
# LARAVEL APP CONFIGURATION
################################################################################

# Application environment: local, staging, production
APP_ENV=local

# Set to false for production, true for local development
APP_DEBUG=true

# Application Key (run: php artisan key:generate)
APP_KEY=

# Application Name
APP_NAME="RentFlow Admin Dashboard"

# Application URL - must match where you're running the backend
# Local: http://localhost:8000 or http://127.0.0.1:8000
# Server: https://your-domain.com or https://your-railway-app.up.railway.app
APP_URL=http://localhost:8000

# Locale configuration
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance driver
APP_MAINTENANCE_DRIVER=file

################################################################################
# DATABASE CONFIGURATION
################################################################################

# For LOCAL development: use sqlite (no additional setup needed)
DB_CONNECTION=sqlite

# For PRODUCTION with MySQL (uncomment and configure):
# DB_CONNECTION=mysql
# DB_HOST=your-database-host.com
# DB_PORT=3306
# DB_DATABASE=rentflow_db
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password

# For PRODUCTION with PostgreSQL (uncomment and configure):
# DB_CONNECTION=pgsql
# DB_HOST=your-database-host.com
# DB_PORT=5432
# DB_DATABASE=rentflow_db
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password

################################################################################
# AUTHENTICATION & SESSION
################################################################################

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log

################################################################################
# CACHING & QUEUES
################################################################################

CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Redis (optional, for production caching):
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Memcached (optional):
# MEMCACHED_HOST=127.0.0.1

################################################################################
# LOGGING & DEBUGGING
################################################################################

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# For production, set LOG_LEVEL=error or warning

################################################################################
# MAIL CONFIGURATION (Optional - for email notifications)
################################################################################

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Alternative for local testing:
# MAIL_MAILER=log

################################################################################
# FRONTEND URL (for CORS)
################################################################################

# LOCAL: Frontend running on http://localhost:5173
FRONTEND_URL=http://localhost:5173

# SERVER: Update to your frontend domain
# FRONTEND_URL=https://your-frontend-domain.com

################################################################################
# OPTIONAL: AWS S3 Configuration (for file storage)
################################################################################

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

################################################################################
# DATABASE SEEDING (for Docker/Server deployment)
################################################################################

# Set to true to automatically run migrations and seed database on startup
RUN_MIGRATIONS=false

################################################################################
# BCRYPT & SECURITY
################################################################################

BCRYPT_ROUNDS=12
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
