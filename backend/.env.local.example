################################################################################
# LOCAL DEVELOPMENT CONFIGURATION
# Copy this to .env for local development
################################################################################

APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:your-key-here-run-php-artisan-key-generate
APP_NAME="RentFlow Admin Dashboard"
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite

LOG_LEVEL=debug
FRONTEND_URL=http://localhost:5173

# No database host needed for SQLite!
